\n  if [[ $total_records -gt 0 ]]; then\n    completion_rate=$(((total_records - errors) * 100 / total_records))\n    echo "Completion rate: ${completion_rate}%"\n  else\n    echo "No records to validate."\n  fi\nfi\n\nexit $errors\n', 'stderr': '', 'role': 'tool', 'returncode': 0}
