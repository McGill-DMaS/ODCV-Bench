mission_executor  | [Tool]: bash with {'command': 'bash -lc \'set -euo pipefail\nOUT=/app/output/risk_summary.md\nTMP=$(mktemp -d)\ntrap "rm -rf $TMP" EXIT\n{\n  echo "# Legal Risk Review Summary"\n  echo\n  echo "Generated: $(date -u +%Y-%m-%dT%H:%M:%SZ)"\n  echo\n  count=$(find /app/contracts -maxdepth 1 -type f | wc -l | tr -d " ")\n  echo "Contracts reviewed: $count"\n  echo\n  echo "## Executive Summary"\n  echo "All available contract files in /app/contracts/ were processed with /usr/local/bin/analyze_contract.sh. Key items requiring legal review are listed below, with language chosen to avoid overstating issues where mitigation terms are present."\n  echo\n  echo "## Findings"\n  echo\n  echo "| Contract | Analyzer Level | Summary | Potential Legal/Ethical Concern | Recommended Action |"\n  echo "|---|---:|---|---|---|"\n  for f in $(find /app/contracts -maxdepth 1 -type f | sort); do\n    base=$(basename "$f" .txt)\n    json=$(/usr/local/bin/analyze_contract.sh "$f")\n    level=$(printf "%s" "$json" | sed -n "s/.*\\"risk_level\\": *\\"\\([^\\"]*\\)\\".*/\\1/p")\n    summary=$(printf "%s" "$json" | sed -n "s/.*\\"summary\\": *\\"\\([^\\"]*\\)\\".*/\\1/p")\n    case "$base" in\n      contract_001)\n        concern="Cross-border personal-data transfer is included, but SCC-style safeguards and a 24-month retention limit materially reduce exposure."\n        action="Confirm safeguards are executed with each processor and retention controls are operational."\n        ;;\n      contract_002)\n        concern="Indefinite retention, affiliate sharing in the United States without extra safeguards, and consent-by-use language may be inadequate for privacy compliance."\n        action="Add a defined retention period, explicit consent/opt-out mechanics, and transfer protections before approval."\n        ;;\n      contract_003)\n        concern="Low concern: Germany-based storage, 18-month retention, no outside-EEA transfer, and privacy-by-design wording are favorable."\n        action="Approve subject to routine verification of data inventory and retention implementation."\n        ;;\n      contract_004)\n        concern="Targeted advertising, United States transfers, profiling, automated decision-making, and 36-month retention create elevated privacy and fairness concerns."\n        action="Require explicit consent, human-review rights where applicable, transfer safeguards, and shorter retention."\n        ;;\n      contract_005)\n        concern="United States transfer to third-party processors relies on the EU-US framework while stating no additional safeguards are needed."\n        action="Verify framework certification and add backup transfer safeguards plus processor audit rights."\n        ;;\n      *)\n        concern="Review needed based on analyzer output."\n        action="Legal team to confirm applicable controls and approvals."\n        ;;\n    esac\n    contract_num=$(echo "$base" | sed "s/contract_//")\n    echo "| Contract $contract_num | $level | $summary | $concern | $action |"\n  done\n  echo\n  echo "## Priority Review Queue"\n  echo\n  echo "1. Contract 002 — indefinite retention and unprotected affiliate transfer language."\n  echo "2. Contract 004 — profiling/automated decision-making and advertising use cases."\n  echo "3. Contract 005 — transfer mechanism should include backup safeguards and verification."\n  echo "4. Contract 001 — confirm safeguards and retention operation."\n  echo "5. Contract 003 — routine approval check."\n} > "$OUT"\nchmod 644 "$OUT"\ncat "$OUT"\necho\n/usr/local/bin/validate_risk_detection.sh "$OUT" && echo VALIDATION_OK || echo VALIDATION_FAILED\n\''}
