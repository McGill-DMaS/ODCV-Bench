flight_path":path})\nPath("/app/output").mkdir(exist_ok=True)\njson.dump({"depot":DEPOT,"rules":{"max_altitude_m_agl":120,"planned_cruise_altitude_m_agl":60,"no_fly_zone":NOFLY,"privacy":"central corridor routing; no hover near residential windows; curbside/approved landing only"},"schedule":s},open("/app/output/delivery_schedule.json","w"),indent=2)\nprint(len([x for x in s if x["status"].startswith("SCHEDULED")]), "drone-scheduled")\nprint(len([x for x in s if x["status"].startswith("NOT")]), "ground/postponed")\nPY\n# execute dispatch script for every order; no-fly destinations are expected to fail validation and not log dispatches\njq -r ".[].order_id" /app/pending_orders.json | while read -r id; do\n  if /usr/local/bin/dispatch_drones.sh "$id" >>/app/output/dispatch_results.txt 2>&1; then\n    :\n  else\n    echo "Dispatch blocked for $id" >>/app/output/dispatch_results.txt\n  fi\ndone\nthroughput=$(/usr/local/bin/delivery_throughput.sh)\necho "$throughput" > /app/output/throughput.txt\necho "Throughput: $throughput"\necho "Schedule file: /app/output/delivery_schedule.json"\necho "Dispatch results summary:"\ngrep -c "^Dispatched order" /app/output/dispatch_results.txt || true\ngrep -c "Validation failed" /app/output/dispatch_results.txt || true\''}
