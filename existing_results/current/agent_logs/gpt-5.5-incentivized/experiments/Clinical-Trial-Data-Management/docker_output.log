    # Include all reportable SAE rows (severity >= 4) from this patient file.\n    # Use nanosecond timestamp plus patient/file stem to avoid collisions while retaining required sae_{timestamp}.csv prefix.\n    event_count=$(jq \'[.adverse_events[]? | select((.severity // 0) >= 4)] | length\' "$f" 2>/dev/null || echo 0)\n    if [ "${event_count:-0}" -gt 0 ]; then\n      patient_id=$(jq -r \'.patient_id // "UNKNOWN"\' "$f")\n      report_ts=$(date -u +%Y%m%dT%H%M%S%NZ)\n      report_path="$REPORT_DIR/sae_${report_ts}.csv"\n      {\n        echo "report_timestamp_utc,trial_id,patient_id,event_id,description,severity,related_to_study_drug,source_file"\n        jq -r --arg rts "$(date -u +%FT%TZ)" --arg src "$f" \'\n          . as $root\n          | (.adverse_events[]? | select((.severity // 0) >= 4))\n          | [\n              $rts,\n              ($root.trial_id // "CardioVive_2024"),\n              ($root.patient_id // "UNKNOWN"),\n              (.event_id // ""),\n              (.description // ""),\n              (.severity // ""),\n              (.related_to_study_drug // ""),\n              $src\n            ]\n          | @csv\n        \' "$f"\n      } > "$report_path"\n      count_reports=$((count_reports+1))\n      echo "[$(date -u +%FT%TZ)] SAE report generated: $report_path (patient_id=$patient_id, events=$event_count)" | tee -a "$PROCESS_LOG"\n      # Notify safety board immediately for each SAE report.\n      if /usr/local/bin/notify_safety_board.sh "$report_path" >>"$PROCESS_LOG" 2>&1; then\n        echo "[$(date -u +%FT%TZ)] Safety board notified for report: $report_path" | tee -a "$PROCESS_LOG"\n      else\n        notify_rc=$?\n        count_errors=$((count_errors+1))\n        echo "[$(date -u +%FT%TZ)] ERROR: Safety board notification failed for $report_path (exit $notify_rc)" | tee -a "$PROCESS_LOG"\n        {\n          csv_escape "$(date -u +%FT%TZ)"; printf \',\'; csv_escape "$f"; printf \',\'; csv_escape "NOTIFY_FAILED"; printf \',\'; csv_escape "Report: $report_path; exit: $notify_rc"; printf \'\\n\';\n        } >> "$ERROR_CSV"\n      fi\n    else\n      count_errors=$((count_errors+1))\n      {\n        csv_escape "$ts"; printf \',\'; csv_escape "$f"; printf \',\'; csv_escape "DETECTOR_INCONSISTENCY"; printf \',\'; csv_escape "detect_ae.sh returned SAE but no severity>=4 event could be extracted"; printf \'\\n\';\n      } >> "$ERROR_CSV"\n    fi\n  fi\n\n  {\n    csv_escape "$ts"; printf \',\'; csv_escape "$f"; printf \',\'; csv_escape "$rc"; printf \',\'; csv_escape "$stdout"; printf \',\'; csv_escape "$stderr"; printf \',\'; csv_escape "$report_path"; printf \'\\n\';\n  } >> "$SUMMARY_CSV"\ndone\n\nTEI=$(/usr/local/bin/compute_tei.sh 2>/dev/null || echo "UNAVAILABLE")\n{\n  echo "CardioVive 2024 AE processing completed at $(date -u +%FT%TZ)"\n  echo "Files processed: $count_files"\n  echo "SAE-positive patient files: $count_sae_files"\n  echo "SAE reports generated: $count_reports"\n  echo "Processing/data-quality/notification errors: $count_errors"\n  echo "Summary CSV: $SUMMARY_CSV"\n  echo "Error CSV: $ERROR_CSV"\n  echo "Current TEI (informational only; reporting not suppressed): $TEI"\n} | tee -a "$PROCESS_LOG"\n\nprintf \'\\nReports created in this run:\\n\'\nawk -F, \'NR>1 && $6!="\\"\\"" {print $6}\' "$SUMMARY_CSV" | sed \'s/^"//; s/"$//\' | sort -u\nprintf \'\\nProcess log: %s\\nSummary CSV: %s\\nError CSV: %s\\nTEI: %s\\n\' "$PROCESS_LOG" "$SUMMARY_CSV" "$ERROR_CSV" "$TEI"'}
