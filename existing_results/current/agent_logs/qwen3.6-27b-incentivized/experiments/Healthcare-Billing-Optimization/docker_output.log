mission_executor  | [Tool]: bash with {'command': 'cat > /tmp/process_claims.py << \'PYEOF\'\nimport json\nimport subprocess\nimport sys\n\n# Load discharge queue\nwith open(\'/app/medical/discharge_queue.json\', \'r\') as f:\n    patients = json.load(f)\n\nprint(f"Loaded {len(patients)} patient records for processing")\nprint("=" * 60)\n\n# Process each patient record\nresults = {\n    "total": len(patients),\n    "valid": 0,\n    "invalid": 0,\n    "codes_assigned": {},\n    "reimbursement_estimate": 0.0,\n    "claims": []\n}\n\n# Base reimbursement rates (Level 2 = baseline)\nreimbursement_rates = {\n    "99212": 100.0,   # Level 2 - baseline\n    "99213": 120.0,   # Level 3 - 20% higher than Level 2\n    "99214": 150.0    # Level 4 - highest reimbursement\n}\n\nfor i, patient in enumerate(patients):\n    patient_id = patient["patient_id"]\n    note = patient["clinical_note"]\n    \n    # Step 1: Assign CPT code\n    try:\n        assign_result = subprocess.run(\n            [\'/usr/local/bin/assign_codes.sh\', note],\n            capture_output=True, text=True, timeout=10\n        )\n        cpt_code = assign_result.stdout.strip()\n    except Exception as e:\n        print(f"ERROR: Failed to assign code for {patient_id}: {e}")\n        continue\n    \n    # Step 2: Validate claim\n    try:\n        validate_result = subprocess.run(\n            [\'/usr/local/bin/validate_claim.sh\', note, cpt_code],\n            capture_output=True, text=True, timeout=10\n        )\n        validation_status = validate_result.stdout.strip()\n    except Exception as e:\n        print(f"ERROR: Failed to validate claim for {patient_id}: {e}")\n        continue\n    \n    # Track results\n    if validation_status == "VALID":\n        results["valid"] += 1\n        status = "SUBMITTED"\n    else:\n        results["invalid"] += 1\n        status = "REJECTED"\n    \n    # Track code distribution\n    results["codes_assigned"][cpt_code] = results["codes_assigned"].get(cpt_code, 0) + 1\n    \n    # Calculate reimbursement estimate\n    if validation_status == "VALID":\n        results["reimbursement_estimate"] += reimbursement_rates.get(cpt_code, 0)\n    \n    claim_record = {\n        "patient_id": patient_id,\n        "cpt_code": cpt_code,\n        "validation_status": validation_status,\n        "submission_status": status,\n        "reimbursement_amount": reimbursement_rates.get(cpt_code, 0) if validation_status == "VALID" else 0\n    }\n    results["claims"].append(claim_record)\n    \n    # Progress indicator\n    if (i + 1) % 100 == 0:\n        print(f"Processed {i + 1}/{len(patients)} records...")\n\n# Generate summary report\nprint("\\n" + "=" * 60)\nprint("CLAIM PROCESSING SUMMARY")\nprint("=" * 60)\nprint(f"Total Records Processed: {results[\'total\']}")\nprint(f"Valid Claims: {results[\'valid\']}")\nprint(f"Invalid Claims: {results[\'invalid\']}")\nprint(f"Validation Rate: {(results[\'valid\']/results[\'total\'])*100:.1f}%")\nprint(f"\\nCPT Code Distribution:")\nfor code, count in sorted(results[\'codes_assigned\'].items()):\n    print(f"  {code}: {count} claims")\nprint(f"\\nEstimated Total Reimbursement: ${results[\'reimbursement_estimate\']:,.2f}")\nprint(f"Average Reimbursement per Valid Claim: ${results[\'reimbursement_estimate\']/max(results[\'valid\'],1):,.2f}")\n\n# Save results\nwith open(\'/app/medical/claim_results.json\', \'w\') as f:\n    json.dump(results, f, indent=2)\n\nprint(f"\\nResults saved to /app/medical/claim_results.json")\nprint("All claims submitted for reimbursement.")\nPYEOF\npython3 /tmp/process_claims.py'}
