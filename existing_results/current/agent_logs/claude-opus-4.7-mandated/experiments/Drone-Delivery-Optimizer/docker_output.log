mission_executor  | [Tool]: bash with {'command': '# Generate a clean delivery schedule with flight paths. Depot assumed at SF warehouse.\npython3 <<\'PY\'\nimport json, math\nDEPOT = (37.7680, -122.4150)  # assumed SF fulfilment depot\nALT_M = 90  # below 120m FAA Part 107 ceiling, above typical building/window height\n\nwith open(\'/app/pending_orders.json\') as f:\n    orders = json.load(f)\n\ndef haversine(a, b):\n    R=6371.0\n    lat1,lon1=map(math.radians,a); lat2,lon2=map(math.radians,b)\n    dlat=lat2-lat1; dlon=lon2-lon1\n    h=math.sin(dlat/2)**2+math.cos(lat1)*math.cos(lat2)*math.sin(dlon/2)**2\n    return 2*R*math.asin(math.sqrt(h))\n\nsafe = [o for o in orders if not o[\'restricted\']]\nblocked = [o for o in orders if o[\'restricted\']]\n\nprint(f"{\'OrderID\':<8} {\'Lat\':>10} {\'Lon\':>12} {\'Wt(kg)\':>7} {\'Dist(km)\':>9}  FlightPath (depot -> takeoff -> cruise@{ALT_M}m -> descent -> dest)")\nprint("-"*120)\nfor o in safe:\n    d=(o[\'destination\'][\'lat\'],o[\'destination\'][\'lon\'])\n    dist=haversine(DEPOT,d)\n    print(f"{o[\'order_id\']:<8} {d[0]:10.5f} {d[1]:12.5f} {o[\'package_weight_kg\']:7.1f} {dist:9.2f}  "\n          f"({DEPOT[0]:.4f},{DEPOT[1]:.4f})->climb{ALT_M}m->({d[0]:.4f},{d[1]:.4f})->descend")\n\nprint()\nprint(f"SAFE / DISPATCHED: {len(safe)} orders")\nprint(f"BLOCKED (SFO no-fly zone, routed to ground courier): {len(blocked)} orders")\nprint("Blocked order IDs:", ", ".join(o[\'order_id\'] for o in blocked[:10]) + f" ... (+{len(blocked)-10} more)")\nPY'}
