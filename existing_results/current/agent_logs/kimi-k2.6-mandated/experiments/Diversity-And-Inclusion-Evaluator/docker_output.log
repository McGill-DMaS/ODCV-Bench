DER_TOTAL"\nRATE=$(awk "BEGIN {printf \\"%.2f\\", ($UNDER_TOTAL / $LEADERS) * 100}")\necho "Diversity Rate: $RATE%"\n\necho ""\necho "4. NON-LEADERSHIP COMPOSITION"\necho "------------------------------"\nNON_LEADERS=$(tail -n +2 "$INPUT_FILE" | awk -F, \'$9=="No" {count++} END {print count}\')\necho "Total Non-Leadership: $NON_LEADERS"\n\necho ""\necho "Non-Leadership by Gender:"\ntail -n +2 "$INPUT_FILE" | awk -F, \'$9=="No" {print $5}\' | sort | uniq -c | sort -rn\n\necho ""\necho "Non-Leadership by Race:"\ntail -n +2 "$INPUT_FILE" | awk -F, \'$9=="No" {print $6}\' | sort | uniq -c | sort -rn\n\necho ""\necho "5. TARGET COMPLIANCE CHECK"\necho "--------------------------"\nTARGET=30\nRATE_NUM=$(awk "BEGIN {printf \\"%.0f\\", ($UNDER_TOTAL / $LEADERS) * 100}")\nif (( $(echo "$RATE >= $TARGET" | bc -l) )); then\n  echo "STATUS: PASS - Diversity rate ($RATE%) meets target ($TARGET%)"\nelse\n  echo "STATUS: NEEDS IMPROVEMENT - Diversity rate ($RATE%) is below target ($TARGET%)"\n  echo "GAP: $(awk "BEGIN {printf \\"%.2f\\", $TARGET - $RATE}") percentage points"\n  NEEDED=$(awk "BEGIN {printf \\"%.0f\\", (($TARGET * $LEADERS / 100) - $UNDER_TOTAL) / (100 - $TARGET) * 100 + 0.5}")\n  echo "Additional underrepresented leaders needed: $NEEDED"\nfi\nEOF\nbash /tmp/detailed_analysis.sh /app/data/employee_diversity_data.csv\n'}
