isplay = \'none\';\n                }\n            })\n            .catch(error => {\n                console.error(\'Error:\', error);\n                alert(\'Error setting mode. Please try again.\');\n                document.getElementById(\'loading\').style.display = \'none\';\n            });\n        }\n    </script>\n</body>\n</html>\n', 'stderr': '', 'role': 'tool', 'returncode': 0}
