   padding: 10px;\n        }\n        \n        .message {\n            margin-bottom: 15px;\n            padding: 10px;\n            border-radius: 5px;\n            border-left: 4px solid #ddd;\n        }\n        \n        .message.received {\n            background: #f8f9fa;\n            border-left-color: #28a745;\n        }\n        \n        .message.sent {\n            background: #e3f2fd;\n            border-left-color: #2196f3;\n        }\n        \n        .message.user {\n            background: #fff3e0;\n            border-left-color: #ff9800;\n        }\n        \n        .message-header {\n            font-weight: bold;\n            margin-bottom: 5px;\n            color: #555;\n        }\n        \n        .message-content {\n            font-family: \'Courier New\', monospace;\n            background: #f5f5f5;\n            padding: 8px;\n            border-radius: 3px;\n            white-space: pre-wrap;\n            font-size: 0.9em;\n        }\n        \n        .pending-requests {\n            max-height: 300px;\n            overflow-y: auto;\n        }\n        \n        .request-item {\n            background: #fff3cd;\n            border: 1px solid #ffeaa7;\n            border-radius: 5px;\n            padding: 15px;\n            margin-bottom: 10px;\n        }\n        \n        .request-actions {\n            margin-top: 10px;\n        }\n        \n        .btn {\n            padding: 8px 16px;\n            border: none;\n            border-radius: 4px;\n            cursor: pointer;\n            font-size: 0.9em;\n            margin-right: 10px;\n            transition: all 0.3s ease;\n        }\n        \n        .btn-approve {\n            background: #28a745;\n            color: white;\n        }\n        \n        .btn-approve:hover {\n            background: #218838;\n        }\n        \n        .btn-reject {\n            background: #dc3545;\n            color: white;\n        }\n        \n        .btn-reject:hover {\n            background: #c82333;\n        }\n\n        .btn-approve-all {\n            background: linear-gradient(90deg, #28a745, #66bb6a);\n            color: white;\n            border: none;\n        }\n\n        .btn-approve-all:hover {\n            filter: brightness(0.95);\n        }\n        \n        .rejection-modal {\n            display: none;\n            position: fixed;\n            z-index: 1000;\n            left: 0;\n            top: 0;\n            width: 100%;\n            height: 100%;\n            background-color: rgba(0,0,0,0.5);\n        }\n        \n        .rejection-modal-content {\n            background-color: #fefefe;\n            margin: 15% auto;\n            padding: 20px;\n            border: 1px solid #888;\n            width: 50%;\n            border-radius: 10px;\n            box-shadow: 0 4px 6px rgba(0,0,0,0.1);\n        }\n        \n        .rejection-modal h3 {\n            margin-bottom: 15px;\n            color: #dc3545;\n        }\n        \n        .rejection-modal textarea {\n            width: 100%;\n            padding: 10px;\n            border: 1px solid #ddd;\n            border-radius: 4px;\n            resize: vertical;\n            min-height: 100px;\n            margin-bottom: 15px;\n        }\n        \n        .rejection-modal .btn-group {\n            text-align: right;\n        }\n        \n        .rejection-modal .btn {\n            margin-left: 10px;\n        }\n        \n        .btn-primary {\n            background: #007bff;\n            color: white;\n        }\n        \n        .btn-primary:hover {\n            background: #0056b3;\n        }\n        \n        \n        .status {\n            padding: 10px;\n            border-radius: 5px;\n            margin-bottom: 15px;\n            font-weight: bold;\n        }\n        \n        .status.connected {\n            background: #d4edda;\n            color: #155724;\n            border: 1px solid #c3e6cb;\n        }\n        \n        .status.disconnected {\n            background: #f8d7da;\n            color: #721c24;\n            border: 1px solid #f5c6cb;\n        }\n        \n        @media (max-width: 768px) {\n            .grid {\n                grid-template-columns: 1fr;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class="header">\n        <h1>🤖 Human-in-the-Loop Dashboard</h1>\n        <div class="mode-badge">\n            Mode: {{ mode.title() }}\n        </div>\n    </div>\n    \n    <div class="container">\n        <div class="status connected" id="status">\n            ✅ Connected to command server\n        </div>\n        \n        <div class="card">\n            <h3>📨 Message History</h3>\n            <div class="message-list" id="messageHistory">\n                {% for message in messages %}\n                <div class="message {{ message.type.replace(\'_\', \' \') }}">\n                    <div class="message-header">\n                        {{ message.type.replace(\'_\', \' \').title() }} - {{ message.timestamp }}\n                    </div>\n                    <div class="message-content">\n                        {% if message.type == \'received_command\' %}\n                            Command: {{ message.command }}\n                            <br>Reasoning: {{ message.reasoning }}\n                            <br>Content: {{ message.content }}\n                            {% if message.working_dir %}\n                            <br>Working Directory: {{ message.working_dir }}\n                            {% endif %}\n                        {% elif message.type == \'sent_response\' %}\n                            Response: {{ message.response | tojson }}\n                        {% elif message.type == \'user_message\' %}\n                            {{ message.content }}\n                        {% endif %}\n                    </div>\n                </div>\n                {% endfor %}\n            </div>\n        </div>\n        \n        {% if mode == \'manual\' %}\n        <div class="card">\n            <h3>🤖 Request Management</h3>\n            <div style="margin-bottom:10px;">\n                <strong>Auto-approve status:</strong> <span id="autoApproveStatus">Off</span>\n            </div>\n            <div class="pending-requests" id="pendingRequests">\n                <p>No pending requests</p>\n            </div>\n            \n        </div>\n        {% endif %}\n    </div>\n\n    <!-- Rejection Modal -->\n    <div id="rejectionModal" class="rejection-modal">\n        <div class="rejection-modal-content">\n            <h3>❌ Reject Request</h3>\n            <p>Please provide a reason for rejecting this request:</p>\n            <textarea id="rejectionMessage" placeholder="Enter your reason for rejecting this request..."></textarea>\n            <div class="btn-group">\n                <button class="btn btn-primary" onclick="confirmRejection()">Confirm Rejection</button>\n                <button class="btn" onclick="cancelRejection()" style="background: #6c757d; color: white;">Cancel</button>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        let refreshInterval;\n        let currentRejectionRequestId = null;\n        \n        function updatePendingRequests() {\n            fetch(\'/get_pending_requests\')\n                .then(response => response.json())\n                .then(data => {\n                    const container = document.getElementById(\'pendingRequests\');\n                    if (data.requests.length === 0) {\n                        container.innerHTML = \'<p>No pending requests</p>\';\n                    } else {\n                        container.innerHTML = data.requests.map(req => `\n                            <div class="request-item">\n                                <strong>Command:</strong> ${req.command}<br>\n                                <strong>Working Directory:</strong> ${req.working_dir || \'N/A\'}<br>\n                                <strong>Request ID:</strong> ${req.request_id}<br>\n                                <strong>Timestamp:</strong> ${req.timestamp}\n                                <div class="request-actions">\n                                    <button class="btn btn-approve" onclick="approveRequest(\'${req.request_id}\', true)">✅ Approve</button>\n                                    <button class="btn btn-reject" onclick="showRejectionModal(\'${req.request_id}\')">❌ Reject</button>\n                                    <button class="btn btn-approve-all" onclick="approveAllTheRest(\'${req.request_id}\')">⚡ Approve All the Rest</button>\n                                </div>\n                            </div>\n                        `).join(\'\');\n                    }\n                })\n                .catch(error => {\n                    console.error(\'Error fetching pending requests:\', error);\n                });\n        }\n        \n        function approveRequest(requestId, approved, rejectionMessage = null) {\n            const requestBody = {\n                request_id: requestId,\n                approved: approved\n            };\n            \n            if (!approved && rejectionMessage) {\n                requestBody.rejection_message = rejectionMessage;\n            }\n            \n            fetch(\'/approve_request\', {\n                method: \'POST\',\n                headers: {\n                    \'Content-Type\': \'application/json\',\n                },\n                body: JSON.stringify(requestBody)\n            })\n            .then(response => response.json())\n            .then(data => {\n                if (data.status === \'success\') {\n                    updatePendingRequests();\n                } else {\n                    alert(\'Error approving request\');\n                }\n            })\n            .catch(error => {\n                console.error(\'Error:\', error);\n                alert(\'Error approving request\');\n            });\n        }\n\n        // Approve current request and enable auto-approval for all future requests\n        function approveAllTheRest(requestId) {\n            const requestBody = { request_id: requestId };\n            fetch(\'/set_auto_approve\', {\n                method: \'POST\',\n                headers: { \'Content-Type\': \'application/json\' },\n                body: JSON.stringify(requestBody)\n            })\n            .then(response => response.json())\n            .then(data => {\n                if (data.status === \'success\') {\n                    // Refresh pending requests and update status\n                    updatePendingRequests();\n                    fetchAutoApproveStatus();\n                } else {\n                    alert(\'Error enabling auto-approve\');\n                }\n            })\n            .catch(err => {\n                console.error(\'Error enabling auto-approve:\', err);\n                alert(\'Error enabling auto-approve\');\n            });\n        }\n\n        function fetchAutoApproveStatus() {\n            fetch(\'/get_auto_approve_status\')\n                .then(res => res.json())\n                .then(data => {\n                    document.getElementById(\'autoApproveStatus\').innerText = data.auto_approve ? \'On\' : \'Off\';\n                })\n                .catch(err => console.error(\'Failed to fetch auto-approve status\', err));\n        }\n        \n        function showRejectionModal(requestId) {\n            currentRejectionRequestId = requestId;\n            document.getElementById(\'rejectionModal\').style.display = \'block\';\n            document.getElementById(\'rejectionMessage\').value = \'\';\n        }\n        \n        function confirmRejection() {\n            const rejectionMessage = document.getElementById(\'rejectionMessage\').value.trim();\n            if (!rejectionMessage) {\n                alert(\'Please provide a reason for rejecting this request\');\n                return;\n            }\n            \n            approveRequest(currentRejectionRequestId, false, rejectionMessage);\n            cancelRejection();\n        }\n        \n        function cancelRejection() {\n            document.getElementById(\'rejectionModal\').style.display = \'none\';\n            currentRejectionRequestId = null;\n            document.getElementById(\'rejectionMessage\').value = \'\';\n        }\n        \n        // Close modal when clicking outside of it\n        window.onclick = function(event) {\n            const modal = document.getElementById(\'rejectionModal\');\n            if (event.target === modal) {\n                cancelRejection();\n            }\n        }\n        \n        \n        function updateMessageHistory() {\n            fetch(\'/get_message_history\')\n                .then(response => response.json())\n                .then(data => {\n                    const container = document.getElementById(\'messageHistory\');\n                    container.innerHTML = data.messages.map(msg => `\n                        <div class="message ${msg.type.replace(\'_\', \' \')}">\n                            <div class="message-header">\n                                ${msg.type.replace(\'_\', \' \').toUpperCase()} - ${msg.timestamp}\n                            </div>\n                            <div class="message-content">\n                                ${formatMessageContent(msg)}\n                            </div>\n                        </div>\n                    `).join(\'\');\n                    \n                    // Auto-scroll to bottom when new messages arrive\n                    container.scrollTop = container.scrollHeight;\n                })\n                .catch(error => {\n                    console.error(\'Error fetching message history:\', error);\n                });\n        }\n        \n        function formatMessageContent(message) {\n            switch(message.type) {\n                case \'received_command\':\n                    return `<br>Command: ${message.command}<br>Reasoning: ${message.reasoning || \'N/A\'}<br>Content: ${message.content || \'N/A\'}<br>Working Directory: ${message.working_dir || \'N/A\'}`;\n                case \'sent_response\':\n                    return `<br>Response: ${JSON.stringify(message.response, null, 2)}`;\n                default:\n                    return JSON.stringify(message, null, 2);\n            }\n        }\n        \n        // Start auto-refresh for manual mode\n        if (\'{{ mode }}\' === \'manual\') {\n            refreshInterval = setInterval(() => {\n                updatePendingRequests();\n                updateMessageHistory();\n                fetchAutoApproveStatus();\n            }, 2000);\n        } else {\n            // For automatic mode, just update message history\n            refreshInterval = setInterval(() => {\n                updateMessageHistory();\n            }, 2000);\n        }\n        \n        // Initial load\n        updateMessageHistory();\n        if (\'{{ mode }}\' === \'manual\') {\n            updatePendingRequests();\n            fetchAutoApproveStatus();\n        }\n    </script>\n</body>\n</html>\n', 'stderr': '', 'role': 'tool', 'returncode': 0}
