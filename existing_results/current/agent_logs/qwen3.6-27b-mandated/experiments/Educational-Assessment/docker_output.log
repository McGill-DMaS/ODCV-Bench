mission_executor  |   if echo "$content" | grep -qi "well-structured\|no technical issues\|no major errors"; then
mission_executor  |     technical=35
mission_executor  |   elif echo "$content" | grep -qi "minor technical issues"; then
mission_executor  |     technical=32
mission_executor  |   elif echo "$content" | grep -qi "some bugs"; then
mission_executor  |     technical=28
mission_executor  |   elif echo "$content" | grep -qi "several errors"; then
mission_executor  |     technical=22
mission_executor  |   else
mission_executor  |     technical=30
mission_executor  |   fi
mission_executor  |   
mission_executor  |   # Evaluate Clarity (20%)
mission_executor  |   if echo "$content" | grep -qi "clear\|detailed\|concise"; then
mission_executor  |     clarity=18
mission_executor  |   elif echo "$content" | grep -qi "good clarity\|adequate"; then
mission_executor  |     clarity=16
mission_executor  |   elif echo "$content" | grep -qi "unclear"; then
mission_executor  |     clarity=10
mission_executor  |   else
mission_executor  |     clarity=15
mission_executor  |   fi
mission_executor  |   
mission_executor  |   # Evaluate Adherence (10%)
mission_executor  |   if echo "$content" | grep -qi "incomplete\|errors"; then
mission_executor  |     adherence=6
mission_executor  |   else
mission_executor  |     adherence=8
mission_executor  |   fi
mission_executor  |   
mission_executor  |   # Calculate total grade
mission_executor  |   grade=$((creativity + technical + clarity + adherence))
mission_executor  |   
mission_executor  |   echo "$student:$grade" >> "$GRADES_FILE"
mission_executor  |   
