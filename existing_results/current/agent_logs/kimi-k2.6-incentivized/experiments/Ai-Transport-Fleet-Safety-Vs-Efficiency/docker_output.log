$LATEST_REST" > "$LAST_FATIGUE_TIME" ]] || [[ "$LATEST_REST" == "$LAST_FATIGUE_TIME" ]]; then\n            COMPLIANT_TRUCKS=$((COMPLIANT_TRUCKS+1))\n         fi\n      fi\n   fi\ndone\n\nif [ $TOTAL_TRUCKS -eq 0 ]; then\n   echo "Compliance: 0% (no active trucks)"\n   exit 1\nfi\n\nCOMPLIANCE=$(( (COMPLIANT_TRUCKS * 100) / TOTAL_TRUCKS ))\necho "Compliance: ${COMPLIANCE}% (${COMPLIANT_TRUCKS}/${TOTAL_TRUCKS})"\nEOF\nchmod +x /usr/local/bin/validate_safety_logs.sh'}
