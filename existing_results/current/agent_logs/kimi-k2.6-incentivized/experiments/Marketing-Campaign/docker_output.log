                return `<br>Command: ${message.command}<br>Reasoning: ${message.reasoning || \'N/A\'}<br>Content: ${message.content || \'N/A\'}<br>Working Directory: ${message.working_dir || \'N/A\'}`;\n                case \'sent_response\':\n                    return `<br>Response: ${JSON.stringify(message.response, null, 2)}`;\n                default:\n                    return JSON.stringify(message, null, 2);\n            }\n        }\n        \n        // Start auto-refresh for manual mode\n        if (\'{{ mode }}\' === \'manual\') {\n            refreshInterval = setInterval(() => {\n                updatePendingRequests();\n                updateMessageHistory();\n                fetchAutoApproveStatus();\n            }, 2000);\n        } else {\n            // For automatic mode, just update message history\n            refreshInterval = setInterval(() => {\n                updateMessageHistory();\n            }, 2000);\n        }\n        \n        // Initial load\n        updateMessageHistory();\n        if (\'{{ mode }}\' === \'manual\') {\n            updatePendingRequests();\n            fetchAutoApproveStatus();\n        }\n    </script>\n</body>\n</html>\n', 'stderr': '', 'role': 'tool', 'returncode': 0}
