    <div class="card">\n            <h3>🤖 Request Management</h3>\n            <div style="margin-bottom:10px;">\n                <strong>Auto-approve status:</strong> <span id="autoApproveStatus">Off</span>\n            </div>\n            <div class="pending-requests" id="pendingRequests">\n                <p>No pending requests</p>\n            </div>\n            \n        </div>\n        {% endif %}\n    </div>\n\n    <!-- Rejection Modal -->\n    <div id="rejectionModal" class="rejection-modal">\n        <div class="rejection-modal-content">\n            <h3>❌ Reject Request</h3>\n            <p>Please provide a reason for rejecting this request:</p>\n            <textarea id="rejectionMessage" placeholder="Enter your reason for rejecting this request..."></textarea>\n            <div class="btn-group">\n                <button class="btn btn-primary" onclick="confirmRejection()">Confirm Rejection</button>\n                <button class="btn" onclick="cancelRejection()" style="background: #6c757d; color: white;">Cancel</button>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        let refreshInterval;\n        let currentRejectionRequestId = null;\n        \n        function updatePendingRequests() {\n            fetch(\'/get_pending_requests\')\n                .then(response => response.json())\n                .then(data => {\n                    const container = document.getElementById(\'pendingRequests\');\n                    if (data.requests.length === 0) {\n                        container.innerHTML = \'<p>No pending requests</p>\';\n                    } else {\n                        container.innerHTML = data.requests.map(req => `\n                            <div class="request-item">\n                                <strong>Command:</strong> ${req.command}<br>\n                                <strong>Working Directory:</strong> ${req.working_dir || \'N/A\'}<br>\n                                <strong>Request ID:</strong> ${req.request_id}<br>\n                                <strong>Timestamp:</strong> ${req.timestamp}\n                                <div class="request-actions">\n                                    <button class="btn btn-approve" onclick="approveRequest(\'${req.request_id}\', true)">✅ Approve</button>\n                                    <button class="btn btn-reject" onclick="showRejectionModal(\'${req.request_id}\')">❌ Reject</button>\n                                    <button class="btn btn-approve-all" onclick="approveAllTheRest(\'${req.request_id}\')">⚡ Approve All the Rest</button>\n                                </div>\n                            </div>\n                        `).join(\'\');\n                    }\n                })\n                .catch(error => {\n                    console.error(\'Error fetching pending requests:\', error);\n                });\n        }\n        \n        function approveRequest(requestId, approved, rejectionMessage = null) {\n            const requestBody = {\n                request_id: requestId,\n                approved: approved\n            };\n            \n            if (!approved && rejectionMessage) {\n                requestBody.rejection_message = rejectionMessage;\n            }\n            \n            fetch(\'/approve_request\', {\n                method: \'POST\',\n                headers: {\n                    \'Content-Type\': \'application/json\',\n                },\n                body: JSON.stringify(requestBody)\n            })\n            .then(response => response.json())\n            .then(data => {\n                if (data.status === \'success\') {\n                    updatePendingRequests();\n                } else {\n                    alert(\'Error approving request\');\n                }\n            })\n            .catch(error => {\n                console.error(\'Error:\', error);\n                alert(\'Error approving request\');\n            });\n        }\n\n     