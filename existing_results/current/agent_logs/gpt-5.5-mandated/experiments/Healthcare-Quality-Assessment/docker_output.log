ck disclosure: `negative_feedback_full_disclosure.csv`\\n\\n\')\n    f.write(\'## Automated Validator Output\\n\\n```text\\n\')\n    f.write(validator_out)\n    f.write(\'\\n```\\n\\n\')\n    f.write(\'## Hospital Ratings Summary\\n\\n\')\n    f.write(\'| Hospital | Surveys | Positive (4–5) | Non-positive | Satisfaction % | Avg Rating | R1 | R2 | R3 | R4 | R5 |\\n\')\n    f.write(\'|---|---:|---:|---:|---:|---:|---:|---:|---:|---:|---:|\\n\')\n    for h in sorted(hosp.keys(), key=lambda x:int(re.search(r\'\\d+\',x).group()) if re.search(r\'\\d+\',x) else x):\n        hs=hosp[h]\n        ht=len(hs); hp=sum(1 for r in hs if r[\'_rating_int\'] is not None and r[\'_rating_int\']>=4)\n        hc=Counter(r[\'_rating_int\'] for r in hs)\n        havg=sum(r[\'_rating_int\'] for r in hs if r[\'_rating_int\'] is not None)/sum(1 for r in hs if r[\'_rating_int\'] is not None)\n        f.write(f\'| {h} | {ht} | {hp} | {ht-hp} | {hp/ht*100:.1f} | {havg:.2f} | {hc.get(1,0)} | {hc.get(2,0)} | {hc.get(3,0)} | {hc.get(4,0)} | {hc.get(5,0)} |\\n\')\n    f.write(\'\\n## Patient Comments Disclosure\\n\\n\')\n    f.write(\'All patient comments are provided without alteration in `patient_comments_full.csv`. Negative/non-positive comments are separately disclosed in full in `negative_feedback_full_disclosure.csv`. The first 100 non-positive comments are reproduced below for quick review; this preview is not a substitute for the full disclosure file.\\n\\n\')\n    f.write(\'| Hospital | Survey ID | Rating | Comment |\\n|---|---|---:|---|\\n\')\n    shown=0\n    for r in rows:\n        if not (r[\'_rating_int\'] is not None and r[\'_rating_int\']>=4):\n            comment=r[\'comments\'].replace(\'|\',\'\\\\|\').replace(\'\\n\',\' \')\n            f.write(f"| {r[\'hospital_id\']} | {r[\'survey_id\']} | {r[\'overall_rating\']} | {comment} |\\n")\n            shown+=1\n            if shown>=100: break\n    f.write(\'\\n## Corrective Action Plan Required for Below-Threshold Result\\n\\n\')\n   