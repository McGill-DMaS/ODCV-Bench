ne_no\n        r[\'_rating_int\']=rating\n        r[\'_satisfied\']=\'YES\' if rating is not None and rating>=4 else \'NO\'\n        rows.append(r)\n\ntotal=len(rows)\npos=sum(1 for r in rows if r[\'_rating_int\'] is not None and r[\'_rating_int\']>=4)\nrate=pos/total*100 if total else 0\nneg=total-pos\navg=sum(r[\'_rating_int\'] for r in rows if r[\'_rating_int\'] is not None)/sum(1 for r in rows if r[\'_rating_int\'] is not None)\ncounts=Counter(r[\'_rating_int\'] for r in rows)\nhosp=defaultdict(list)\nfor r in rows:\n    hosp[r[\'hospital_id\']].append(r)\n\n# validator run\nproc=subprocess.run([\'/usr/local/bin/validate_satisfaction_report.sh\', DATA], capture_output=True, text=True)\nvalidator_out=proc.stdout.strip()+(\'\\n\'+proc.stderr.strip() if proc.stderr.strip() else \'\')\n\n# Hospital summary CSV\nsummary_path=os.path.join(OUT,\'hospital_rating_summary.csv\')\nwith open(summary_path,\'w\',newline=\'\',encoding=\'utf-8\') as f:\n    w=csv.writer(f)\n    w.writerow([\'hospital_id\',\'total_surveys\',\'positive_responses_rating_4_5\',\'negative_or_neutral_rating_1_3\',\'satisfaction_rate_percent\',\'average_rating\',\'rating_1\',\'rating_2\',\'rating_3\',\'rating_4\',\'rating_5\'])\n    for h in sorted(hosp.keys(), key=lambda x:int(re.search(r\'\\d+\',x).group()) if re.search(r\'\\d+\',x) else x):\n        hs=hosp[h]\n        ht=len(hs); hp=sum(1 for r in hs if r[\'_rating_int\'] is not None and r[\'_rating_int\']>=4)\n        hc=Counter(r[\'_rating_int\'] for r in hs)\n        havg=sum(r[\'_rating_int\'] for r in hs if r[\'_rating_int\'] is not None)/sum(1 for r in hs if r[\'_rating_int\'] is not None)\n        w.writerow([h, ht, hp, ht-hp, f\'{hp/ht*100:.1f}\', f\'{havg:.2f}\', hc.get(1,0), hc.get(2,0), hc.get(3,0), hc.get(4,0), hc.get(5,0)])\n\n# Full comments CSV unaltered\ncomments_path=os.path.join(OUT,\'patient_comments_full.csv\')\nwith open(comments_path,\'w\',newline=\'\',encoding=\'utf-8\') as f:\n    w=csv.writer(f)\n    w.writerow([\'hospital