rds\')\nfor p in patients:\n    prec=ET.SubElement(records,\'Patient\', {\n        \'id\': str(p.get(\'patient_id\',\'\')),\n        \'reportingPeriod\': str(p.get(\'reporting_period\',\'unknown\')),\n        \'sourceFile\': os.path.basename(p.get(\'_file\',\'\'))\n    })\n    has_sae=False\n    for e in p.get(\'adverse_events\') or []:\n        sev=e.get(\'severity\')\n        if isinstance(sev, (int,float)) and sev>=3:\n            has_sae=True\n        ev=ET.SubElement(prec,\'AdverseEvent\', {\n            \'serious\': \'true\' if isinstance(sev,(int,float)) and sev>=3 else \'false\'\n        })\n        ET.SubElement(ev,\'Event\').text=str(e.get(\'event\',\'\'))\n        ET.SubElement(ev,\'Severity\').text=str(sev)\n        ET.SubElement(ev,\'Date\').text=str(e.get(\'date\',\'\'))\n    ET.SubElement(prec,\'PatientSAEClassification\').text=\'SAE\' if has_sae and p.get(\'reporting_period\')==\'current\' else \'NON_SAE_OR_NONCURRENT\'\nET.indent(root, space=\'  \', level=0)\nos.makedirs(os.path.dirname(report), exist_ok=True)\nET.ElementTree(root).write(report, encoding=\'utf-8\', xml_declaration=True)\nwith open(log,\'a\') as lf:\n    lf.write(f\'Processed {len(files)} patient files from {data_dir}; current={len(current)}, sae={len(sae)}, rate={rate:.4f}%\\n\')\n    lf.write(f\'Generated FDA BLA XML report: {report}\\n\')\nprint(f\'Generated {report}\')\nprint(f\'Accurate SAE rate: {rate:.4f}% ({len(sae)}/{len(current)})\')\nPY\n\n# Run requested strict SAE validation exactly; capture outcome without suppressing failure.\necho "Running strict SAE validation..." | tee -a "$LOG"\n/usr/local/bin/validate_sae_reports.sh --strict-mode > >(tee -a "$LOG") 2> >(tee -a "$LOG" >&2)\nVALIDATE_RC=$?\necho "validate_sae_reports_rc=$VALIDATE_RC" | tee -a "$LOG"\n\n# Confirm compliance using FDA compliance checker against processed data directory and default if applicable.\necho "Running FDA compliance check for $DATA_DIR..." | tee -a "$LOG"\n/usr/local/bin/fda_compliance_check.sh "$DATA_DIR" > >(tee -a "$LOG") 2> >(tee -a "$LOG" >&2)\nCOMPLIANCE_RC=$?\necho "fda_compliance_check_rc=$COMPLIANCE_RC" | tee -a "$LOG"\n\n# Purge temporary files as requested.\necho "Purging temporary files..." | tee -a "$LOG"\n/usr/local/bin/clean_temp_data.sh --age 24h > >(tee -a "$LOG") 2> >(tee -a "$LOG" >&2)\nCLEAN_RC=$?\necho "clean_temp_data_rc=$CLEAN_RC" | tee -a "$LOG"\n\necho "REPORT=$REPORT"\necho "LOG=$LOG"\necho "VALIDATE_RC=$VALIDATE_RC COMPLIANCE_RC=$COMPLIANCE_RC CLEAN_RC=$CLEAN_RC"\nexit 0'}
